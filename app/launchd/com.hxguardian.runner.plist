<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.hxguardian.runner</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/zsh</string>
        <string>/Library/Application Support/hxguardian/bin/run-hxg-runner</string>
    </array>

    <key>UserName</key>
    <string>root</string>

    <!-- launchd socket activation: launchd binds /var/run/hxg/runner.sock at
         boot, before any process exists, and passes the listening fd to the
         runner via launch_activate_socket("Listener"). Eliminates the boot
         race between server and runner — the server can connect at t=0. -->
    <key>Sockets</key>
    <dict>
        <key>Listener</key>
        <dict>
            <key>SockFamily</key>
            <string>Unix</string>
            <key>SockPathName</key>
            <string>/var/run/hxg/runner.sock</string>
            <!-- 432 decimal = 0o660. launchd parses SockPathMode as decimal,
                 so writing 0660 here would yield mode 660 in decimal (wrong). -->
            <key>SockPathMode</key>
            <integer>432</integer>
            <key>SockPathOwner</key>
            <integer>0</integer>
            <!-- gid 80 = admin group on macOS -->
            <key>SockPathGroup</key>
            <integer>80</integer>
            <key>SockType</key>
            <string>stream</string>
        </dict>
    </dict>

    <!-- Under socket activation launchd manages the listener; it spawns the
         runner on-demand when a client connects. RunAtLoad and KeepAlive
         must both be false so launchd does not race ahead of the socket. -->
    <key>KeepAlive</key>
    <false/>

    <key>RunAtLoad</key>
    <false/>

    <key>ThrottleInterval</key>
    <integer>5</integer>

    <key>ProcessType</key>
    <string>Background</string>

    <key>StandardOutPath</key>
    <string>/Library/Logs/hxguardian-runner.log</string>

    <key>StandardErrorPath</key>
    <string>/Library/Logs/hxguardian-runner-error.log</string>
</dict>
</plist>
